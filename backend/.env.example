PORT=8080
ENV=development
CORS_ORIGINS=*

# API keys (server-side only — never ship these in the mobile app)
CAT_API_KEY=your-thecatapi-key
GROQ_API_KEY=your-groq-key
GUIDE_GROQ_API_KEY=your-guide-groq-key

# Path to frontend/src for serving comic panel assets
FRONTEND_ASSETS_PATH=../frontend/src

# Cache TTLs (Go duration strings)
CACHE_TTL_CATS=15m
CACHE_TTL_FACTS=1h
CACHE_TTL_BREEDS=24h

# Rate limit: max requests per IP per minute
RATE_LIMIT_PER_MIN=120

# Optional: Supabase Postgres direct connection for content persistence
# DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
