EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Production / preview builds must use a public HTTPS URL (not localhost).
# Deploy the Go backend first, then set this to that URL.
EXPO_PUBLIC_API_URL=https://your-api.example.com

# Optional client fallbacks when the backend is unavailable.
# Prefer keeping Groq and Cat API keys on the server only.
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GUIDE_GROQ_API_KEY=
EXPO_PUBLIC_CAT_API_KEY=
